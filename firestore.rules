rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidEntry(data) {
      return data.keys().hasAll(['name', 'message', 'createdAt']) && 
             data.keys().size() == 3 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 500 &&
             data.createdAt == request.time;
    }

    match /guestbook/{entryId} {
      // Allow anyone to read the guestbook
      allow list, get: if true;
      
      // Allow anyone to create an entry
      allow create: if isValidEntry(request.resource.data);
      
      // No one can update or delete entries (keep it simple and secure)
      allow update, delete: if false;
    }
  }
}
